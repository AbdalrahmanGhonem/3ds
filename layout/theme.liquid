<!doctype html>
{%- liquid
  assign lang_code = request.locale.iso_code | split: '-' | first | downcase
  assign is_rtl = lang_code == 'ar'
  assign dir_setting = is_rtl | default: false | ternary: 'rtl', 'ltr'
-%}
<html lang="{{ request.locale.iso_code }}" dir="{{ dir_setting }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>{{ page_title }}</title>
    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}
    <link rel="preload" href="{{ 'hero-keychain.svg' | asset_url }}" as="image">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Work+Sans:wght@400;500&family=Cairo:wght@500;700&display=swap" rel="stylesheet">
    {{ 'theme.css' | asset_url | stylesheet_tag }}
    {{ content_for_header }}
  </head>
  <body class="template-{{ template | replace: '.', '-' }} {% if is_rtl %}rtl{% endif %}" data-lang="{{ lang_code }}">
    <div class="page-shell">
      {% section 'header' %}
      <main id="main-content" role="main">
        {{ content_for_layout }}
      </main>
      {% section 'footer' %}
    </div>
    {% render 'cart-drawer' %}
    {{ 'theme.js' | asset_url | script_tag | replace: '<script ', '<script defer ' }}
  </body>
</html>
