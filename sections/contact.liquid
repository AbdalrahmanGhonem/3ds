<section class="section contact">
  <div class="container">
    <div class="card animate">
      <div class="flex-between" style="align-items: flex-start; margin-bottom: 12px;">
        <div>
          <div class="tag">{{ 'contact.tag' | t }}</div>
          <h2 class="title-lg" style="margin: 8px 0;">{{ section.settings.heading }}</h2>
          <p class="text">{{ section.settings.copy }}</p>
        </div>
        <span class="badge">{{ section.settings.badge }}</span>
      </div>
      {%- form 'contact', id: 'ContactForm' -%}
        <div class="grid">
          <input class="input" type="text" name="contact[name]" placeholder="{{ 'contact.name' | t }}" required>
          <input class="input" type="email" name="contact[email]" placeholder="{{ 'contact.email' | t }}" required>
          <textarea class="input" name="contact[body]" rows="4" placeholder="{{ 'contact.message' | t }}" required></textarea>
        </div>
        <button class="button" type="submit" style="margin-top: 12px;">{{ 'contact.submit' | t }}</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tell us your idea." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Need a bulk order or custom shape? Send us a note and we’ll reply in EN or AR." },
    { "type": "text", "id": "badge", "label": "Badge", "default": "Replies in <24h" }
  ]
}
{% endschema %}
