<section class="section faq">
  <div class="container">
    <div class="flex-between" style="align-items: flex-start; margin-bottom: 12px;">
      <div>
        <div class="tag">{{ 'faq.tag' | t }}</div>
        <h2 class="title-lg">{{ section.settings.heading }}</h2>
        <p class="text">{{ section.settings.copy }}</p>
      </div>
    </div>
    <div class="accordion">
      {%- for block in section.blocks -%}
        <div class="accordion-item animate" data-accordion>
          <button class="accordion-header" aria-expanded="false">
            <span>{{ block.settings.question }}</span>
            <span aria-hidden="true">+</span>
          </button>
          <div class="accordion-body">
            <p>{{ block.settings.answer }}</p>
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Questions, answered." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Shipping, materials, and customization details for your 3D printed keychains." }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ item",
      "settings": [
        { "type": "text", "id": "question", "label": "Question", "default": "How long does shipping take?" },
        { "type": "textarea", "id": "answer", "label": "Answer", "default": "Orders are printed and shipped locally within 2-4 business days across Egypt." }
      ]
    }
  ],
  "max_blocks": 6,
  "default": {
    "blocks": [
      {
        "type": "faq",
        "settings": {
          "question": "How long does printing take?",
          "answer": "Standard prints ship in 2-4 business days. Rush options available at checkout."
        }
      },
      {
        "type": "faq",
        "settings": {
          "question": "Can I add custom text?",
          "answer": "Yes. Add your name or short text in the personalization box on the product page."
        }
      },
      {
        "type": "faq",
        "settings": {
          "question": "What materials do you use?",
          "answer": "Premium PLA+/PETG with durable split rings. Metallic and neon finishes on request."
        }
      }
    ]
  }
}
{% endschema %}
