<section class="section" id="featured">
  <div class="container">
    <div class="flex-between" style="align-items: flex-start; margin-bottom: 18px;">
      <div>
        <div class="tag">{{ 'featured.tag' | t }}</div>
        <h2 class="title-lg" style="margin: 10px 0;">{{ section.settings.heading }}</h2>
        <p class="text">{{ section.settings.copy }}</p>
      </div>
      <a class="button secondary" href="{{ routes.collections_url }}">{{ 'featured.view_all' | t }}</a>
    </div>
    {%- liquid
      assign featured_collection = collections[section.settings.collection]
      if featured_collection == nil or featured_collection.all_products_count == 0
        assign featured_collection = collections.all
      endif
    -%}
    <div class="product-grid">
      {%- for product in featured_collection.products limit: section.settings.limit -%}
        <article class="card product-card animate">
          <a href="{{ product.url }}">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '480x480' }}" alt="{{ product.featured_image.alt | default: product.title }}">
            {%- else -%}
              <div class="pill">{{ 'featured.no_image' | t }}</div>
            {%- endif -%}
          </a>
          <div class="product-info">
            <div>
              <strong>{{ product.title }}</strong>
              <div class="price">
                {{ product.price | money_with_currency }}
              </div>
            </div>
            <form method="post" action="/cart/add">
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button class="button secondary" type="submit">{{ 'featured.cta' | t }}</button>
            </form>
          </div>
        </article>
      {%- else -%}
        <div class="card animate">
          <p class="text">{{ 'featured.empty' | t }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured products",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured keychains" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Top-selling personalized 3D keychains, printed with premium materials and ready for delivery." },
    { "type": "collection", "id": "collection", "label": "Featured collection" },
    { "type": "range", "id": "limit", "label": "Product limit", "min": 2, "max": 12, "default": 6, "step": 1 }
  ]
}
{% endschema %}
