{%- liquid
  assign hero_image = section.settings.hero_image | default: blank
  if hero_image != blank
    assign hero_image_url = hero_image | img_url: '720x'
  else
    assign hero_image_url = 'hero-keychain.svg' | asset_url
  endif
-%}
<section class="section">
  <div class="container hero">
    <div class="animate">
      <div class="tag">{{ section.settings.tagline }}</div>
      <h1 class="title-lg">{{ section.settings.heading }}</h1>
      <p class="text">{{ section.settings.copy }}</p>
      <div class="flex" style="margin-top: 18px; flex-wrap: wrap;">
        <a class="button" href="{{ section.settings.primary_link | default: routes.collections_url }}">
          {{ section.settings.primary_label }}
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14m0 0-6-6m6 6-6 6" stroke="#05060b" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a class="button secondary" href="{{ section.settings.secondary_link | default: '#featured' }}">{{ section.settings.secondary_label }}</a>
      </div>
      <div class="hero-badges">
        <span class="pill">{{ 'hero.badge_print' | t }}</span>
        <span class="pill">{{ 'hero.badge_delivery' | t }}</span>
        <span class="pill">{{ 'hero.badge_materials' | t }}</span>
      </div>
    </div>
    <div class="hero-visual animate floating">
      <img src="{{ hero_image_url }}" alt="{{ section.settings.heading }}">
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "3D printed in Cairo" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "3D Printed Keychains" },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "Personalized 3D printed keychains made in Egypt with premium materials and bold finishes." },
    { "type": "text", "id": "primary_label", "label": "Primary Button Label", "default": "Shop keychains" },
    { "type": "url", "id": "primary_link", "label": "Primary Button Link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary Button Label", "default": "View collection" },
    { "type": "url", "id": "secondary_link", "label": "Secondary Button Link" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" }
  ]
}
{% endschema %}
