<section class="section" style="padding-top: 0;">
  <div class="container payment-strip">
    <span class="text" style="font-weight: 700;">{{ section.settings.heading }}</span>
    <img src="{{ 'payment-card.svg' | asset_url }}" alt="{{ 'footer.card' | t }}">
    <img src="{{ 'payment-instapay.svg' | asset_url }}" alt="InstaPay">
    <img src="{{ 'payment-vodafone.svg' | asset_url }}" alt="Vodafone Cash">
    <span class="badge">{{ section.settings.badge }}</span>
  </div>
</section>

{% schema %}
{
  "name": "Payment strip",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Pay securely with cards, InstaPay, or Vodafone Cash" },
    { "type": "text", "id": "badge", "label": "Badge", "default": "EGP only" }
  ]
}
{% endschema %}
