<section class="section">
  <div class="container story">
    <div class="animate story-block">
      <div class="tag">{{ 'story.tag' | t }}</div>
      <h2 class="title-lg" style="margin: 12px 0;">{{ section.settings.heading }}</h2>
      <p class="text">{{ section.settings.copy }}</p>
    </div>
    <div class="grid">
      <div class="card animate">
        <strong>{{ section.settings.card_one_title }}</strong>
        <p class="text">{{ section.settings.card_one_body }}</p>
      </div>
      <div class="card animate">
        <strong>{{ section.settings.card_two_title }}</strong>
        <p class="text">{{ section.settings.card_two_body }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Story",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Bold, durable, personal." },
    { "type": "textarea", "id": "copy", "label": "Copy", "default": "We design and 3D print keychains in Cairo with meticulous finishing, premium plastics, and quality control on every order." },
    { "type": "text", "id": "card_one_title", "label": "Card 1 title", "default": "Local & fast" },
    { "type": "textarea", "id": "card_one_body", "label": "Card 1 body", "default": "Printed and shipped from Egypt with delivery updates in EN/AR." },
    { "type": "text", "id": "card_two_title", "label": "Card 2 title", "default": "Custom finishes" },
    { "type": "textarea", "id": "card_two_body", "label": "Card 2 body", "default": "Matte, neon, metallic accents with durable split rings." }
  ]
}
{% endschema %}
