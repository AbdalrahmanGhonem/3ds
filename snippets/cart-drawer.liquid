<div class="cart-drawer" data-cart-drawer aria-hidden="true">
  <div class="cart-backdrop" data-cart-close></div>
  <aside class="cart-panel" role="dialog" aria-label="{{ 'cart.title' | t }}">
    <div class="flex-between" style="align-items: center;">
      <strong>{{ 'cart.title' | t }}</strong>
      <button class="button secondary" type="button" data-cart-close>{{ 'cart.close' | t }}</button>
    </div>
    {%- if cart.item_count == 0 -%}
      <div class="card animate visible">
        <p class="text">{{ 'cart.empty' | t }}</p>
      </div>
    {%- else -%}
      {%- for item in cart.items -%}
        <div class="cart-line" data-qty>
          <div>
            <div>{{ item.product.title }}</div>
            <div class="price">{{ item.price | money }}</div>
          </div>
          <div class="qty">
            <button type="button" data-qty-change="-1" aria-label="Decrease">−</button>
            <span data-qty-value>{{ item.quantity }}</span>
            <button type="button" data-qty-change="1" aria-label="Increase">+</button>
          </div>
        </div>
      {%- endfor -%}
      <div class="flex-between">
        <span class="text">{{ 'cart.total' | t }}</span>
        <strong class="price">{{ cart.total_price | money_with_currency }}</strong>
      </div>
      <a class="button" href="{{ routes.cart_url }}">{{ 'cart.view_cart' | t }}</a>
      <a class="button secondary" href="{{ routes.checkout_url }}">{{ 'cart.checkout' | t }}</a>
    {%- endif -%}
  </aside>
</div>
