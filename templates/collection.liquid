<section class="section">
  <div class="container">
    <div class="flex-between" style="align-items: center; margin-bottom: 12px;">
      <div>
        <div class="tag">{{ collection.title }}</div>
        <h1 class="title-lg">{{ collection.title }}</h1>
        {%- if collection.description != blank -%}
          <div class="text">{{ collection.description }}</div>
        {%- endif -%}
      </div>
      <span class="badge">{{ 'collections.count' | t }}: {{ collection.all_products_count }}</span>
    </div>
    <div class="product-grid">
      {%- for product in collection.products -%}
        <article class="card product-card animate">
          <a href="{{ product.url }}">
            {%- if product.featured_image -%}
              <img src="{{ product.featured_image | img_url: '480x480' }}" alt="{{ product.featured_image.alt | default: product.title }}">
            {%- endif -%}
          </a>
          <div class="product-info">
            <div>
              <strong>{{ product.title }}</strong>
              <div class="price">{{ product.price | money_with_currency }}</div>
            </div>
            <a class="button secondary" href="{{ product.url }}">{{ 'collections.view' | t }}</a>
          </div>
        </article>
      {%- else -%}
        <p class="text">{{ 'collections.empty' | t }}</p>
      {%- endfor -%}
    </div>
  </div>
</section>
